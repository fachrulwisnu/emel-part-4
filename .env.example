# ==============================================================================
# CONFIGURATION & SECRET ENVIRONMENT VARIABLES (.env)
# ==============================================================================
# Copy the contents of this file to a new file named `.env` in the root directory.
# These keys are securely resolved on the server-side to prevent client-side leaks.

# 1. CORE SYSTEM VARIABLES (Injected automatically in AI Studio preview)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# 2. NVIDIA API KEYS FOR MULTI-MODEL SPLIT-TASK AI ARCHITECTURE
# Anda bisa mengisi masing-masing key di bawah ini untuk model spesifik,
# atau mengisi NVIDIA_API_KEY utama saja sebagai payung seluruh model.

# Key Utama NVIDIA (Fallback jika key model spesifik di bawah kosong)
NVIDIA_API_KEY=""

# Key Spesifik untuk Model thinkingmachines/inkling (Primary JSON Data Extractor)
NVIDIA_API_KEY_INKLING=""

# Key Spesifik untuk Model minimaxai/minimax-m3 (Contextual Tagger & Urgency)
NVIDIA_API_KEY_MINIMAX=""

# Key Tambahan Failover (GLM-5.2 / Nemotron / Gemma / DeepSeek)
NVIDIA_API_KEY_NEMOTRON=""
NVIDIA_API_KEY_DEEPSEEK=""
NVIDIA_API_KEY_GEMMA=""
NVIDIA_API_KEY_GEMMA4=""

# 3. SUPABASE DATABASE CONFIGURATION (Real-time sync target)
DATABASE_URL=""
SUPABASE_URL=""
SUPABASE_KEY=""

